        "# part4\n",
        "import os\n",
        "import pandas as pd\n",
        "from sklearn.feature_extraction.text import TfidfVectorizer\n",
        "from sklearn.cluster import KMeans\n",
        "from sklearn.decomposition import PCA\n",
        "from sklearn.metrics import accuracy_score\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# --- 1. تحميل البيانات من ملف CSV ---\n",
        "file_path = \"/content/spam.csv\"\n",
        "df = pd.read_csv(file_path)\n",
        "\n",
        "# --- 2. التحقق من الأعمدة المتاحة ---\n",
        "print(\"Available columns:\", df.columns)\n",
        "\n",
        "# --- 3. اختيار العمود الذي يحتوي على النصوص ---\n",
        "if 'Message' in df.columns:\n",
        "    documents = df['Message'].dropna().tolist()\n",
        "else:\n",
        "    raise ValueError(\"Column 'Message' not found in the CSV file.\")\n",
        "\n",
        "# --- 4. تحويل النصوص إلى قيم عددية باستخدام TF-IDF ---\n",
        "vectorizer = TfidfVectorizer(stop_words='english')\n",
        "X = vectorizer.fit_transform(documents)\n",
        "\n",
        "# --- 5. تطبيق K-Means لتجميع النصوص إلى مجموعتين ---\n",
        "kmeans = KMeans(n_clusters=2, random_state=42, n_init=10)\n",
        "predicted_labels = kmeans.fit_predict(X)\n",
        "\n",
        "# --- 6. تقليل الأبعاد لعرض النتائج بصريًا باستخدام PCA ---\n",
        "pca = PCA(n_components=2)\n",
        "X_pca = pca.fit_transform(X.toarray())\n",
        "\n",
        "# --- 7. عرض الرسمة ---\n",
        "plt.figure(figsize=(8, 6))\n",
        "plt.scatter(X_pca[:, 0], X_pca[:, 1], c=predicted_labels, cmap='viridis')\n",
        "plt.title('Document Clusters')\n",
        "plt.xlabel('PCA 1')\n",
        "plt.ylabel('PCA 2')\n",
        "plt.colorbar(label='Cluster')\n",
        "plt.show()\n",
        "\n",
        "# --- 8. حساب الدقة (اختياري) إذا كان عندنا تصنيفات حقيقية ---\n",
        "if 'Label' in df.columns:\n",
        "    true_labels = df['Label'].map({'ham': 0, 'spam': 1}).values  # تأكد من التسمية في ملفك\n",
        "    accuracy = accuracy_score(true_labels, predicted_labels)\n",
        "    print(f\"Clustering Accuracy: {accuracy * 100:.2f}%\")\n",
        "else:\n",
        "    print(\"No 'Label' column found for accuracy calculation.\")\n"
      ],
