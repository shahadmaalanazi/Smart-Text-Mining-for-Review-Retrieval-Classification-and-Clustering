    {
      "cell_type": "code",
      "source": [
        "import math\n",
        "\n",
        "# لحساب عدد المستندات اللي تحتوي على الكلمة w\n",
        "def counting_docs(w, docs):\n",
        "    count = 0\n",
        "    for r in range(len(docs)):\n",
        "        if w in docs[r]:\n",
        "            count += 1\n",
        "    return count\n",
        "\n",
        "# لحساب IDF لكل كلمة\n",
        "def calc_IDF(w, documents):\n",
        "    return math.log10(len(documents) / counting_docs(w, documents))\n",
        "\n",
        "# لحساب مصفوفة TF-IDF\n",
        "def Calc_TF_IDF(document, wordDict):\n",
        "    TF_IDF = []\n",
        "    for r in range(len(document)):\n",
        "        row = []\n",
        "        for w in wordDict:\n",
        "            TF = document[r].count(w) / len(document[r])\n",
        "            row.append(round(TF * calc_IDF(w, document), 3))\n",
        "        TF_IDF.append(row)\n",
        "    return TF_IDF"
      ],
      "metadata": {
        "id": "dSqwV5RkM-79"
      },
      "execution_count": null,
      "outputs": []
