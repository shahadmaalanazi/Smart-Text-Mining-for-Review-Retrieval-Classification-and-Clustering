        "#part2\nimport numpy as np\nfrom sklearn.metrics.pairwise import cosine_similarity\nfrom sklearn.feature_extraction.text import TfidfVectorizer\n\n# إنشاء قائمة الكلمات (wordDict)\nflat_list = [item for sublist in normalized_docs for item in sublist]\nwordDict = list(dict.fromkeys(flat_list))\n\n# دالة حساب التشابه\ndef calculate_cosine_similarity(query_vec, document_vecs):\n    return cosine_similarity([query_vec], document_vecs)\n\n# الاستعلامات\nqueries = [\n    \"bad customer service at the salon\",\n    \"unpleasant salon experience\",\n    \"overpriced and not professional\",\n    \"salon appointment was delayed and staff unfriendly\",\n    \"gorgeous quality hair treatment and nail cleaning\",\n    \"the good haircut service and results\",\n    \"waited too long and didn't like the haircut\",\n    \"the salon service was professional and friendly\"\n]\n\n# relevant_docs: عدلي حسب البيانات الحقيقية\nrelevant_docs = ['Golden_Glow', 'Chic_Charm_Salon', 'Glow_Up_Studio', 'Lavish_Looks',\n                 'Pearl_Perfection', 'Serenity_Salon', 'Velvet_Vanity', 'Blush_&_Bloom',\n                 'Diva_s_Den', 'Glamour_Touch', 'Luxe_Locks', 'Radiance_Studio',\n                 'The_Beauty_Bar', 'Bella_Beauty_Lounge']\n\ntop_n = 10\n\n# معالجة كل استعلام بشكل منفصل\nfor i, query in enumerate(queries, 1):\n    print(f\"\\n{'='*50}\")\n    print(f\"Query {i}: {query}\")\n    print('='*50)\n\n    # تطبيع الاستعلام\n    query_normalized = ' '.join(normalize(query))\n\n    # بناء TF-IDF\n    vectorizer = TfidfVectorizer(vocabulary=wordDict)\n    all_texts = [' '.join(doc) for doc in normalized_docs] + [query_normalized]\n    tfidf_matrix = vectorizer.fit_transform(all_texts)\n\n    query_vec = tfidf_matrix[-1].toarray()[0]\n    document_vecs = tfidf_matrix[:-1]\n\n    # حساب التشابه\n    similarities = calculate_cosine_similarity(query_vec, document_vecs)\n    similarities_flat = similarities.flatten()\n    sorted_indices = similarities_flat.argsort()[-top_n:][::-1]\n\n    # عرض النتائج مع النسبة\n    print(\"Top retrieval documents based on cosine similarity:\\n\")\n    for idx in sorted_indices:\n        percentage = similarities_flat[idx]\n        print(f\"- {text_titles[idx]} | Similarity: {percentage:.2f}\")\n\n    # حساب Precision و Recall\n    retrieved_docs = [df.index[idx] for idx in sorted_indices[:top_n]]\n    true_positives = set(retrieved_docs).intersection(set(relevant_docs))\n\n    precision = len(true_positives) / len(retrieved_docs) if retrieved_docs else 0\n    recall = len(true_positives) / len(relevant_docs) if relevant_docs else 0\n\n    print(f\"\\nPrecision: {precision:.2f}\")\n    print(f\"Recall: {recall:.2f}\")\n"
