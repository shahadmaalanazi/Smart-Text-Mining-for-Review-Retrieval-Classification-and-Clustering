    {
      "cell_type": "code",
      "source": [
        "#part1\n",
        "# استيراد المكتبات\n",
        "import nltk\n",
        "import spacy\n",
        "from nltk.corpus import stopwords\n",
        "from nltk.tokenize import word_tokenize\n",
        "import string\n",
        "import glob\n",
        "\n",
        "# تحميل موارد NLTK\n",
        "nltk.download('stopwords')\n",
        "nltk.download('punkt')\n",
        "nltk.download('punkt_tab') # Download the punkt_tab data\n",
        "\n",
        "# تحميل نموذج spaCy\n",
        "nlp = spacy.load(\"en_core_web_sm\")\n",
        "\n",
        "# التهيئة\n",
        "stop_words = set(stopwords.words('english'))\n",
        "\n",
        "# دالة التنظيف باستخدام spaCy lemmatizer\n",
        "def normalize(text):\n",
        "    tokens = word_tokenize(text.lower())\n",
        "    words = [w for w in tokens if w.isalpha() and w not in stop_words]\n",
        "\n",
        "    # تمرير الكلمات إلى spaCy للحصول على lemmas\n",
        "    doc = nlp(\" \".join(words))\n",
        "    lemmas = [token.lemma_ for token in doc]\n",
        "\n",
        "    return lemmas\n",
        "\n",
        "# تحديد مسار الملفات\n",
        "folder_path = \"/content/drive/MyDrive/Colab Notebooks/All folders\"\n",
        "text_files = glob.glob(f\"{folder_path}/*.txt\")\n",
        "text_files.sort()\n",
        "\n",
        "original_docs = []\n",
        "normalized_docs = []\n",
        "\n",
        "# قراءة وتطبيق normalization على كل ملف\n",
        "for txt_file in text_files:\n",
        "    with open(txt_file, 'r', encoding='utf-8') as f:\n",
        "        content = f.read()\n",
        "        original_docs.append(content)\n",
        "        normalized_docs.append(normalize(content))\n",
        "\n",
        "for i in range(len(text_files)):\n",
        "    print(f\"\\n{'='*40}\")\n",
        "    print(f\"File {i+1}: {text_files[i]}\")\n",
        "    print(f\"{'-'*20}\\nOriginal:\\n{original_docs[i]}\")\n",
        "    print(f\"{'-'*20}\\nNormalized:\\n{normalized_docs[i]}\")\n"
      ],
      "metadata": {
