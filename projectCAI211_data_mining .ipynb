    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "from pathlib import Path\n",
        "import glob\n",
        "\n",
        "# استدعاء الملفات المعدلة\n",
        "lemmatized_folder = \"/content/drive/MyDrive/Colab Notebooks/lemmatized_tokens\"\n",
        "lemmatized_files = glob.glob(f\"{lemmatized_folder}/*.txt\")\n",
        "lemmatized_files.sort()\n",
        "\n",
        "# تجهيز النصوص في قائمة\n",
        "normalized_docs = []\n",
        "for file_path in lemmatized_files:\n",
        "    with open(file_path, 'r', encoding='utf-8') as file:\n",
        "        text = file.read().split()\n",
        "        normalized_docs.append(text)\n",
        "\n",
        "# تجميع كل الكلمات في قائمة وحدة\n",
        "flat_list = []\n",
        "for sublist in normalized_docs:\n",
        "    for item in sublist:\n",
        "        flat_list.append(item)\n",
        "\n",
        "# إزالة التكرار للحصول على الكلمات الفريدة فقط\n",
        "wordDict = list(dict.fromkeys(flat_list))\n",
        "\n",
        "# حساب TF-IDF\n",
        "TF_IDF = Calc_TF_IDF(normalized_docs, wordDict)\n",
        "\n",
        "# تجهيز أسماء الملفات كمؤشر\n",
        "text_titles = [Path(path).stem for path in lemmatized_files]\n",
        "\n",
        "# عرض النتائج في جدول\n",
        "df = pd.DataFrame(TF_IDF, index=text_titles, columns=wordDict)\n",
        "df"
      ],
